Algoritmo CondicionalMultiple1
	Definir dia Como Entero;
	Escribir "Ingrese un día (1-7): " Sin Saltar;
	Leer dia;
	Segun dia Hacer
		1:
			Escribir "Lunes";
		2:
			Escribir "Martes";
		3: 
			Escribir "Miércoles";
		4: 
			Escribir "Jueves";
		5:
			Escribir "Viernes";
		6: 
			Escribir "Sábado";
		7: 
			Escribir "Domingo";
		De Otro Modo:
			Escribir "El día no existe";
	FinSegun
FinAlgoritmo

Algoritmo CicloPara
	Definir i, n Como Entero
	// Bucle infinito
	// Para i = 1 Hasta 2 Con Paso 0 Hacer
	// 		Escribir "Estoy dentro del ciclo para"
	// FinPara
	Leer n; // 20
	Para i = 1 Hasta  n Con Paso 1 Hacer
		Si i % 2 = 0 Entonces
			Escribir i, " ", Sin Saltar;
		FinSi		
	FinPara	
	Escribir ""
FinAlgoritmo

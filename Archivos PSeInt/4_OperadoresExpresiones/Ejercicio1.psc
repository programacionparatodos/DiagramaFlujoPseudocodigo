Algoritmo Ejercicio1
	Definir radio, area, VALOR_PI Como Real;

	Escribir "Ingrese el radio del círculo: " Sin Saltar;
	Leer radio;
	
	VALOR_PI = 3.1416;
	
	area = VALOR_PI * radio ^ 2;
	
	Escribir "El área del círculo es: ", area;
FinAlgoritmo


Algoritmo OperadoresComparacion
	// Definir variables
	Definir a, b Como Real;
	
	Escribir "Ingresa el valor para A: ";
	Leer a;
	Escribir "Ingresa el valor para B: ";
	Leer b;
	
	Escribir "¿A es igual a B? ", (a = b);
	Escribir "¿A es diferente a B? ", (a <> b);
	Escribir "¿A es menor a B? ", (a < b);
	Escribir "¿A es mayor a B? ", (a > b);
	Escribir "¿A es b a B? ", (a <= b);
	Escribir "¿A es mayor o igual a B? ", (a >= b);
FinAlgoritmo
